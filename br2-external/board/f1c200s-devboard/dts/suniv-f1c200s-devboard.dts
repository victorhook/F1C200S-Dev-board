// SPDX-License-Identifier: (GPL-2.0+ OR MIT)
// Device tree for F1C200S Dev Board Rev A
// Linux kernel version (include path relative to arch/arm/boot/dts/)

/dts-v1/;
#include "allwinner/suniv-f1c100s.dtsi"
#include <dt-bindings/clock/suniv-ccu-f1c100s.h>
#include <dt-bindings/reset/suniv-ccu-f1c100s.h>
#include <dt-bindings/gpio/gpio.h>
#include <dt-bindings/input/input.h>

/ {
	model = "F1C200S Dev Board";
	compatible = "custom,f1c200s-devboard",
		     "allwinner,suniv-f1c200s",
		     "allwinner,suniv-f1c100s";

	aliases {
		mmc0 = &mmc0;
		serial0 = &uart0;
		serial1 = &uart1;
	};

	chosen {
		stdout-path = "serial0:115200n8";
	};

	memory@80000000 {
		device_type = "memory";
		reg = <0x80000000 0x04000000>; /* 64 MB */
	};

	reg_vcc3v3: reg-vcc3v3 {
		compatible = "regulator-fixed";
		regulator-name = "vcc3v3";
		regulator-min-microvolt = <3300000>;
		regulator-max-microvolt = <3300000>;
	};

	leds {
		compatible = "gpio-leds";

		led1 {
			label = "devboard:led1";
			gpios = <&pio 3 12 GPIO_ACTIVE_HIGH>; /* PD12 */
			linux,default-trigger = "heartbeat";
		};

		led2 {
			label = "devboard:led2";
			gpios = <&pio 2 3 GPIO_ACTIVE_HIGH>; /* PC3 */
		};

		led3 {
			label = "devboard:led3";
			gpios = <&pio 3 0 GPIO_ACTIVE_HIGH>; /* PD0 */
		};

		led4 {
			label = "devboard:led4";
			gpios = <&pio 3 11 GPIO_ACTIVE_HIGH>; /* PD11 */
			linux,default-trigger = "mmc0";
		};
	};

	gpio-keys {
		compatible = "gpio-keys";
		pinctrl-names = "default";
		pinctrl-0 = <&button1_pd9_pin>, <&button2_pd10_pin>;

		button-1 {
			label = "User Button 1";
			linux,code = <KEY_ENTER>;
			gpios = <&pio 3 9 GPIO_ACTIVE_LOW>; /* PD9 */
		};

		button-2 {
			label = "User Button 2";
			linux,code = <KEY_ESC>;
			gpios = <&pio 3 10 GPIO_ACTIVE_LOW>; /* PD10 */
		};
	};

	/*
	 * TVOUT - Composite video output on TVOUT pin (pin 72)
	 * The display pipeline nodes (fe0, be0, tcon0) are not yet in
	 * mainline suniv-f1c100s.dtsi. Once upstreamed, enable with:
	 *   &fe0   { status = "okay"; };
	 *   &be0   { status = "okay"; };
	 *   &tcon0 { status = "okay"; };
	 *
	 * TVIN - Composite video input on TVIN0/TVIN1 pins (pins 78/77)
	 * Requires V4L2 driver for suniv TV decoder (not in mainline).
	 */
};

/* Nodes not in mainline suniv dtsi yet - define inline */
&{/soc} {
	uart1: serial@1c25400 {
		compatible = "snps,dw-apb-uart";
		reg = <0x01c25400 0x400>;
		interrupts = <2>;
		reg-shift = <2>;
		reg-io-width = <4>;
		clocks = <&ccu CLK_BUS_UART1>;
		resets = <&ccu RST_BUS_UART1>;
		pinctrl-names = "default";
		pinctrl-0 = <&uart1_pd_pins>;
		status = "okay";
	};
};

&pio {
	uart1_pd_pins: uart1-pd-pins {
		pins = "PD3", "PD4";
		function = "uart1";
	};

	spi0_pd_pins: spi0-pd-pins {
		pins = "PD18", "PD19", "PD20", "PD21";
		function = "spi0";
	};

	ir_rx_pins: ir-rx-pins {
		pins = "PE3";
		function = "ir0";
	};

	button1_pd9_pin: button1-pd9-pin {
		pins = "PD9";
		function = "gpio_in";
		bias-pull-up;
	};

	button2_pd10_pin: button2-pd10-pin {
		pins = "PD10";
		function = "gpio_in";
		bias-pull-up;
	};
};

/* UART0 on PE0/PE1 - camera connector J4 (primary console) */
&uart0 {
	pinctrl-names = "default";
	pinctrl-0 = <&uart0_pe_pins>;
	status = "okay";
};

/* SD card on SDC0 (PF0-PF5) - boot device */
&mmc0 {
	vmmc-supply = <&reg_vcc3v3>;
	/*
	 * Conservative timing for bring-up/debug: if high-speed or 4-bit
	 * transfers are marginal on this board, ext4 metadata reads can fail.
	 * Raise these back after boot is stable.
	 */
	bus-width = <1>;
	max-frequency = <12000000>;
	no-1-8-v;
	broken-cd;
	disable-wp;
	status = "okay";
};

&otg_sram {
	status = "okay";
};

&usb_otg {
	dr_mode = "otg";
	status = "okay";
};

&usbphy {
	status = "okay";
};

/* SPI0 on PD18-PD21 (mux 4) - wired to display header */
&spi0 {
	pinctrl-names = "default";
	pinctrl-0 = <&spi0_pd_pins>;
	status = "okay";

	/* ST7735R TFT display
	 * SPI: CS=PD18, MOSI=PD19, CLK=PD20, MISO=PD21
	 * DC and reset on PD7/PD8 - adjust to match your wiring.
	 */
	display@0 {
		compatible = "jianda,jd-t18003-t01";
		reg = <0>;
		spi-max-frequency = <32000000>;
		dc-gpios = <&pio 3 7 GPIO_ACTIVE_HIGH>;    /* PD7 */
		reset-gpios = <&pio 3 8 GPIO_ACTIVE_LOW>;   /* PD8 */
		rotation = <0>;
		status = "disabled";
	};
};

/* IR receiver on PE3 (directly accessible on header) */
/*
 * NOTE: The suniv IR controller node may not be in the mainline dtsi.
 * If missing, it can be defined similarly to uart1 above at address
 * 0x01c22c00. The IR_RX pin is routed to the board headers.
 */
