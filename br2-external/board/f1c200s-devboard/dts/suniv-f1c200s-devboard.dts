// SPDX-License-Identifier: (GPL-2.0+ OR MIT)
// Device tree for F1C200S Dev Board Rev A
// Linux kernel version (include path relative to arch/arm/boot/dts/)

/dts-v1/;
#include "allwinner/suniv-f1c100s.dtsi"
#include <dt-bindings/clock/suniv-ccu-f1c100s.h>
#include <dt-bindings/reset/suniv-ccu-f1c100s.h>
#include <dt-bindings/gpio/gpio.h>
#include <dt-bindings/input/input.h>

/ {
	model = "F1C200S Dev Board";
	compatible = "custom,f1c200s-devboard",
		     "allwinner,suniv-f1c200s",
		     "allwinner,suniv-f1c100s";

	aliases {
		mmc0 = &mmc0;
		serial0 = &uart0;
		serial1 = &uart1;
	};

	chosen {
		stdout-path = "serial0:115200n8";
	};

	memory@80000000 {
		device_type = "memory";
		reg = <0x80000000 0x04000000>; /* 64 MB */
	};

	reg_vcc3v3: reg-vcc3v3 {
		compatible = "regulator-fixed";
		regulator-name = "vcc3v3";
		regulator-min-microvolt = <3300000>;
		regulator-max-microvolt = <3300000>;
	};

	leds {
		compatible = "gpio-leds";

		led1 {
			label = "devboard:led1";
			gpios = <&pio 3 12 GPIO_ACTIVE_HIGH>; /* PD12 */
			linux,default-trigger = "heartbeat";
		};

		led2 {
			label = "devboard:led2";
			gpios = <&pio 2 3 GPIO_ACTIVE_HIGH>; /* PC3 */
		};

		led3 {
			label = "devboard:led3";
			gpios = <&pio 3 0 GPIO_ACTIVE_HIGH>; /* PD0 */
		};

		led4 {
			label = "devboard:led4";
			gpios = <&pio 3 11 GPIO_ACTIVE_HIGH>; /* PD11 */
			linux,default-trigger = "mmc0";
		};
	};

	gpio-keys {
		compatible = "gpio-keys";
		pinctrl-names = "default";
		pinctrl-0 = <&button1_pd9_pin>, <&button2_pd10_pin>;

		button-1 {
			label = "User Button 1";
			linux,code = <KEY_ENTER>;
			gpios = <&pio 3 9 GPIO_ACTIVE_LOW>; /* PD9 */
		};

		button-2 {
			label = "User Button 2";
			linux,code = <KEY_ESC>;
			gpios = <&pio 3 10 GPIO_ACTIVE_LOW>; /* PD10 */
		};
	};

	/*
	 * TVOUT - Composite video output on TVOUT pin (pin 72)
	 * The display pipeline nodes (fe0, be0, tcon0) are not yet in
	 * mainline suniv-f1c100s.dtsi. Once upstreamed, enable with:
	 *   &fe0   { status = "okay"; };
	 *   &be0   { status = "okay"; };
	 *   &tcon0 { status = "okay"; };
	 *
	 * TVIN - Composite video input on TVIN0/TVIN1 pins (pins 78/77)
	 * Requires V4L2 driver for suniv TV decoder (not in mainline).
	 */

	/* Dummy 24 MHz clock handed to the OV2640 driver as "xvclk".
	 * The camera module has its own onboard crystal; the driver
	 * just needs a clk phandle it can call clk_prepare_enable() on.
	 * fixed-clock makes that a no-op.
	 */
	ov2640_xvclk: ov2640-xvclk {
		compatible = "fixed-clock";
		#clock-cells = <0>;
		clock-frequency = <24000000>;
	};
};

/* Nodes not in mainline suniv dtsi yet - define inline */
&{/soc} {
	uart1: serial@1c25400 {
		compatible = "snps,dw-apb-uart";
		reg = <0x01c25400 0x400>;
		interrupts = <2>;
		reg-shift = <2>;
		reg-io-width = <4>;
		clocks = <&ccu CLK_BUS_UART1>;
		resets = <&ccu RST_BUS_UART1>;
		pinctrl-names = "default";
		pinctrl-0 = <&uart1_pd_pins>;
		status = "okay";
	};

	/* CSI (parallel camera interface).
	 *
	 * Requires the sun4i-csi suniv compatible patch under linux-patches/.
	 *
	 * Pin conflict with UART0 console: PE0/PE1 carry CSI HSYNC/VSYNC
	 * but are also the UART0 TX/RX console pins. When you enable CSI
	 * (status = "okay" below), either:
	 *   a) set status = "disabled" on &uart0, and switch the console
	 *      to /dev/ttyGS0 (USB gadget, already set up in rcS), OR
	 *   b) accept that the serial console goes silent while camera runs.
	 *
	 * IRQ 24 is best-guess for CSI on suniv; verify against the F1C100S
	 * datasheet interrupt table before trusting it in production.
	 */
	csi0: csi@1cb0000 {
		compatible = "allwinner,suniv-f1c100s-csi";
		reg = <0x01cb0000 0x1000>;
		interrupts = <32>;
		clocks = <&ccu CLK_BUS_CSI>, <&ccu CLK_DRAM_CSI>;
		clock-names = "bus", "ram";
		resets = <&ccu RST_BUS_CSI>;
		pinctrl-names = "default";
		pinctrl-0 = <&csi_pe_pins>;
		status = "okay";

		port {
			csi_in: endpoint {
				remote-endpoint = <&ov2640_out>;
				bus-width = <8>;
				hsync-active = <1>;
				vsync-active = <1>;
				pclk-sample = <1>;
			};
		};
	};
};

&pio {
	vcc-pc-supply = <&reg_vcc3v3>;
	vcc-pd-supply = <&reg_vcc3v3>;
	vcc-pe-supply = <&reg_vcc3v3>;
	vcc-pf-supply = <&reg_vcc3v3>;

	uart1_pd_pins: uart1-pd-pins {
		pins = "PD3", "PD4";
		function = "uart1";
	};

	spi0_pd_pins: spi0-pd-pins {
		pins = "PD18", "PD19", "PD20", "PD21";
		function = "spi0";
	};

	ir_rx_pins: ir-rx-pins {
		pins = "PE11";
		function = "ir";
	};

	button1_pd9_pin: button1-pd9-pin {
		pins = "PD9";
		function = "gpio_in";
		bias-pull-up;
	};

	button2_pd10_pin: button2-pd10-pin {
		pins = "PD10";
		function = "gpio_in";
		bias-pull-up;
	};

	/* CSI DVP: PE0=HSYNC, PE1=VSYNC, PE2=PCLK, PE3-PE10=D0-D7 */
	csi_pe_pins: csi-pe-pins {
		pins = "PE0", "PE1", "PE2", "PE3", "PE4",
		       "PE5", "PE6", "PE7", "PE8", "PE9", "PE10";
		function = "csi";
	};

	/* SCCB for OV2640 sensor (I2C1 on PD5/PD6 per board schematic) */
	i2c1_pd_pins: i2c1-pd-pins {
		pins = "PD5", "PD6";
		function = "i2c1";
	};
};

/* UART0 on PE0/PE1 — shares pins with CSI HSYNC/VSYNC.
 * When activating the camera stack, flip this to "disabled" and enable
 * &csi0 + &i2c1 — console moves to /dev/ttyGS0 over USB gadget.
 */
&uart0 {
	pinctrl-names = "default";
	pinctrl-0 = <&uart0_pe_pins>;
	status = "disabled";
};

/* SD card on SDC0 (PF0-PF5) - boot device */
&mmc0 {
	vmmc-supply = <&reg_vcc3v3>;
	bus-width = <4>;
	no-1-8-v;     /* SD card at 3.3V only; we don't support UHS-I signaling */
	broken-cd;    /* no card-detect pin wired */
	disable-wp;   /* no write-protect pin wired */
	status = "okay";
};

&otg_sram {
	status = "okay";
};

&usb_otg {
	dr_mode = "peripheral";
	status = "okay";
};

&usbphy {
	status = "okay";
};

/* SPI0 on PD18-PD21 (mux 4) - wired to display header */
&spi0 {
	pinctrl-names = "default";
	pinctrl-0 = <&spi0_pd_pins>;
	status = "okay";

	/* ST7735R TFT display
	 * SPI: CS=PD18, MOSI=PD19, CLK=PD20, MISO=PD21
	 * DC and reset on PD7/PD8 - adjust to match your wiring.
	 * If you see garbled pixels, try dropping spi-max-frequency to 16 MHz.
	 */
	display@0 {
		compatible = "jianda,jd-t18003-t01";
		reg = <0>;
		spi-max-frequency = <32000000>;
		dc-gpios = <&pio 3 7 GPIO_ACTIVE_HIGH>;    /* PD7 */
		/* This module has an inverter on RST (or clone wiring) — the chip's
		 * reset is physically active-high from the header's point of view.
		 * Using GPIO_ACTIVE_LOW leaves the display permanently reset (white).
		 */
		reset-gpios = <&pio 3 8 GPIO_ACTIVE_HIGH>;  /* PD8 */
		rotation = <0>;
		status = "okay";
	};
};

/* IR receiver on PE3 (directly accessible on header) */
/*
 * NOTE: The suniv IR controller node may not be in the mainline dtsi.
 * If missing, it can be defined similarly to uart1 above at address
 * 0x01c22c00. The IR_RX pin is routed to the board headers.
 */

/* I2C1 = SCCB bus for OV2640. Enabled alongside &csi0 for camera use. */
&i2c1 {
	pinctrl-names = "default";
	pinctrl-0 = <&i2c1_pd_pins>;
	clock-frequency = <100000>;
	status = "okay";

	ov2640: camera@30 {
		compatible = "ovti,ov2640";
		reg = <0x30>;
		clocks = <&ov2640_xvclk>;
		clock-names = "xvclk";
		/* Net mapping confirmed from schematic:
		 *   CAM_RESET → PD17  (SoC pin 25, active-low)
		 *   CAM_PWDN  → PC1   (active-high, still to be double-checked)
		 * Previous PC2 was actually the FEL net — wrong pin.
		 */
		resetb-gpios = <&pio 3 17 GPIO_ACTIVE_LOW>;
		pwdn-gpios = <&pio 2 1 GPIO_ACTIVE_HIGH>;

		port {
			ov2640_out: endpoint {
				remote-endpoint = <&csi_in>;
				bus-width = <8>;
				hsync-active = <1>;
				vsync-active = <1>;
				pclk-sample = <1>;
			};
		};
	};
};
