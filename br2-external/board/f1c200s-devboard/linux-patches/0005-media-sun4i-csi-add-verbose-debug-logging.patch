From: Victor <victor.krook@everdrone.com>
Date: Fri, 24 Apr 2026 23:30:00 +0200
Subject: [PATCH] media: sun4i-csi: add verbose debug logging for buffer flow

Add intentionally verbose logging to the sun4i CSI driver so we can
observe:

- stream start register programming
- which vb2 buffer gets assigned to each hardware slot
- which slot gets marked done on each interrupt
- whether VSYNC / overflow / capture-done interrupts fire
- the raw buffer control / status register state around each transition

This is a temporary diagnostics patch for the F1C200S OV2640 bring-up.

Signed-off-by: Victor <victor.krook@everdrone.com>
---
 drivers/media/platform/sunxi/sun4i-csi/sun4i_csi.h |  11 ++
 drivers/media/platform/sunxi/sun4i-csi/sun4i_dma.c | 109 ++++++++++++++++++++
 2 files changed, 120 insertions(+)

diff --git a/drivers/media/platform/sunxi/sun4i-csi/sun4i_csi.h b/drivers/media/platform/sunxi/sun4i-csi/sun4i_csi.h
--- a/drivers/media/platform/sunxi/sun4i-csi/sun4i_csi.h
+++ b/drivers/media/platform/sunxi/sun4i-csi/sun4i_csi.h
@@ -38,8 +38,19 @@
 #define CSI_BUF_CTRL_DBE			BIT(0)
 
 #define CSI_INT_EN_REG			0x30
+#define CSI_INT_VSYNC				BIT(7)
+#define CSI_INT_HBLANK_OVERFLOW		BIT(6)
+#define CSI_INT_FIFO2_OVERFLOW		BIT(4)
+#define CSI_INT_FIFO1_OVERFLOW		BIT(3)
+#define CSI_INT_FIFO0_OVERFLOW		BIT(2)
 #define CSI_INT_FRM_DONE			BIT(1)
 #define CSI_INT_CPT_DONE			BIT(0)
+#define CSI_INT_DEBUG_MASK			(CSI_INT_VSYNC | \
+						 CSI_INT_HBLANK_OVERFLOW | \
+						 CSI_INT_FIFO2_OVERFLOW | \
+						 CSI_INT_FIFO1_OVERFLOW | \
+						 CSI_INT_FIFO0_OVERFLOW | \
+						 CSI_INT_FRM_DONE | CSI_INT_CPT_DONE)
 
 #define CSI_INT_STA_REG			0x34
 
diff --git a/drivers/media/platform/sunxi/sun4i-csi/sun4i_dma.c b/drivers/media/platform/sunxi/sun4i-csi/sun4i_dma.c
--- a/drivers/media/platform/sunxi/sun4i-csi/sun4i_dma.c
+++ b/drivers/media/platform/sunxi/sun4i-csi/sun4i_dma.c
@@ -16,6 +16,67 @@
 
 #include "sun4i_csi.h"
 
+static void sun4i_csi_log_regs(struct sun4i_csi *csi, const char *tag)
+{
+	dev_info(csi->dev,
+		 "%s: EN=0x%08x CFG=0x%08x CAP=0x%08x BUF_CTL=0x%08x BUF_STA=0x%08x INT_EN=0x%08x INT_STA=0x%08x HSIZE=0x%08x VSIZE=0x%08x BUF_LEN=0x%08x\n",
+		 tag,
+		 readl(csi->regs + CSI_EN_REG),
+		 readl(csi->regs + CSI_CFG_REG),
+		 readl(csi->regs + CSI_CPT_CTRL_REG),
+		 readl(csi->regs + CSI_BUF_CTRL_REG),
+		 readl(csi->regs + 0x2c),
+		 readl(csi->regs + CSI_INT_EN_REG),
+		 readl(csi->regs + CSI_INT_STA_REG),
+		 readl(csi->regs + CSI_WIN_CTRL_W_REG),
+		 readl(csi->regs + CSI_WIN_CTRL_H_REG),
+		 readl(csi->regs + CSI_BUF_LEN_REG));
+	dev_info(csi->dev,
+		 "%s: FIFO0[A]=0x%08x FIFO0[B]=0x%08x FIFO1[A]=0x%08x FIFO1[B]=0x%08x FIFO2[A]=0x%08x FIFO2[B]=0x%08x\n",
+		 tag,
+		 readl(csi->regs + CSI_BUF_ADDR_REG(0, 0)),
+		 readl(csi->regs + CSI_BUF_ADDR_REG(0, 1)),
+		 readl(csi->regs + CSI_BUF_ADDR_REG(1, 0)),
+		 readl(csi->regs + CSI_BUF_ADDR_REG(1, 1)),
+		 readl(csi->regs + CSI_BUF_ADDR_REG(2, 0)),
+		 readl(csi->regs + CSI_BUF_ADDR_REG(2, 1)));
+}
+
+static void sun4i_csi_log_slot_state(struct sun4i_csi *csi, const char *tag,
+				     unsigned int slot)
+{
+	struct vb2_v4l2_buffer *v_buf = csi->current_buf[slot];
+
+	if (!v_buf) {
+		dev_info(csi->dev, "%s: slot%u current_buf=NULL\n", tag, slot);
+		return;
+	}
+
+	dev_info(csi->dev,
+		 "%s: slot%u vb=%p index=%u sequence=%u field=%u planes=%u payloads=[%lu,%lu,%lu]\n",
+		 tag, slot, v_buf, v_buf->vb2_buf.index, v_buf->sequence,
+		 v_buf->field, v_buf->vb2_buf.num_planes,
+		 v_buf->vb2_buf.num_planes > 0 ? vb2_get_plane_payload(&v_buf->vb2_buf, 0) : 0,
+		 v_buf->vb2_buf.num_planes > 1 ? vb2_get_plane_payload(&v_buf->vb2_buf, 1) : 0,
+		 v_buf->vb2_buf.num_planes > 2 ? vb2_get_plane_payload(&v_buf->vb2_buf, 2) : 0);
+}
+
+static void sun4i_csi_log_irq_bits(struct sun4i_csi *csi, u32 reg)
+{
+	dev_info(csi->dev,
+		 "irq: raw=0x%08x [VS=%u HB_OF=%u F2_OF=%u F1_OF=%u F0_OF=%u FD=%u CD=%u] buf_ctl=0x%08x buf_sta=0x%08x\n",
+		 reg,
+		 !!(reg & CSI_INT_VSYNC),
+		 !!(reg & CSI_INT_HBLANK_OVERFLOW),
+		 !!(reg & CSI_INT_FIFO2_OVERFLOW),
+		 !!(reg & CSI_INT_FIFO1_OVERFLOW),
+		 !!(reg & CSI_INT_FIFO0_OVERFLOW),
+		 !!(reg & CSI_INT_FRM_DONE),
+		 !!(reg & CSI_INT_CPT_DONE),
+		 readl(csi->regs + CSI_BUF_CTRL_REG),
+		 readl(csi->regs + 0x2c));
+}
+
 struct sun4i_csi_buffer {
 	struct vb2_v4l2_buffer	vb;
 	struct list_head	list;
@@ -99,6 +160,10 @@
 	dev_dbg(csi->dev,
 		"No more available buffer, using the scratch buffer\n");
 
+	dev_info(csi->dev,
+		 "scratch: assigning scratch buffer to slot%u base=0x%pad size=%zu\n",
+		 slot, &csi->scratch.paddr, csi->scratch.size);
+
 	for (plane = 0; plane < csi->fmt.num_planes; plane++) {
 		writel(addr, csi->regs + CSI_BUF_ADDR_REG(plane, slot));
 		addr += csi->fmt.plane_fmt[plane].sizeimage;
@@ -136,8 +201,21 @@
 		buf_addr = vb2_dma_contig_plane_dma_addr(&v_buf->vb2_buf,
 							 plane);
 		writel(buf_addr, csi->regs + CSI_BUF_ADDR_REG(plane, slot));
+		dev_info(csi->dev,
+			 "fill_slot: slot%u plane%u -> dma=0x%pad size=%u bpl=%u vb_index=%u\n",
+			 slot, plane, &buf_addr,
+			 csi->fmt.plane_fmt[plane].sizeimage,
+			 csi->fmt.plane_fmt[plane].bytesperline,
+			 v_buf->vb2_buf.index);
 	}
 
+	dev_info(csi->dev,
+		 "fill_slot: slot%u now owns vb=%p index=%u num_planes=%u queued_list_empty=%u\n",
+		 slot, v_buf, v_buf->vb2_buf.index, v_buf->vb2_buf.num_planes,
+		 list_empty(&csi->buf_list));
+	sun4i_csi_log_slot_state(csi, "fill_slot", slot);
+	sun4i_csi_log_regs(csi, "fill_slot");
+
 	return 0;
 }
 
@@ -168,6 +246,10 @@
 
 	v_buf = csi->current_buf[slot];
 	v_buf->field = csi->fmt.field;
+	dev_info(csi->dev,
+		 "mark_done: slot%u vb=%p index=%u sequence=%u timestamp_before=%llu\n",
+		 slot, v_buf, v_buf->vb2_buf.index, sequence,
+		 (unsigned long long)v_buf->vb2_buf.timestamp);
 	v_buf->sequence = sequence;
 	v_buf->vb2_buf.timestamp = ktime_get_ns();
 	vb2_buffer_done(&v_buf->vb2_buf, VB2_BUF_STATE_DONE);
@@ -179,12 +261,21 @@
 {
 	u32 reg = readl(csi->regs + CSI_BUF_CTRL_REG);
 	unsigned int next;
+	unsigned int dbs = !!(reg & CSI_BUF_CTRL_DBS);
+	unsigned int dbn = !!(reg & CSI_BUF_CTRL_DBN);
 
 	/* Our next buffer is not the current buffer */
 	next = !(reg & CSI_BUF_CTRL_DBS);
+	dev_info(csi->dev,
+		 "buffer_flip: seq=%u buf_ctl=0x%08x DBS=%u DBN=%u -> retiring slot%u and refilling slot%u\n",
+		 sequence, reg, dbs, dbn, next, next);
+	sun4i_csi_log_slot_state(csi, "buffer_flip-before", 0);
+	sun4i_csi_log_slot_state(csi, "buffer_flip-before", 1);
 
 	/* Report the previous buffer as done */
 	sun4i_csi_buffer_mark_done(csi, next, sequence);
+	sun4i_csi_log_slot_state(csi, "buffer_flip-after-mark_done", 0);
+	sun4i_csi_log_slot_state(csi, "buffer_flip-after-mark_done", 1);
 
 	/* Put a new buffer in there */
 	return sun4i_csi_buffer_fill_slot(csi, next);
@@ -198,6 +289,10 @@
 
 	spin_lock_irqsave(&csi->qlock, flags);
 	list_add_tail(&buf->list, &csi->buf_list);
+	dev_info(csi->dev,
+		 "buffer_queue: vb=%p index=%u num_planes=%u queued_empty_after_add=%u\n",
+		 &buf->vb, buf->vb.vb2_buf.index, buf->vb.vb2_buf.num_planes,
+		 list_empty(&csi->buf_list));
 	spin_unlock_irqrestore(&csi->qlock, flags);
 }
 
@@ -238,6 +333,11 @@
 		return -EINVAL;
 
 	dev_dbg(csi->dev, "Starting capture\n");
+	dev_info(csi->dev,
+		 "start_streaming: count=%u width=%u height=%u pixfmt=0x%08x num_planes=%u scratch_pending=%zu\n",
+		 count, csi->fmt.width, csi->fmt.height, csi->fmt.pixelformat,
+		 csi->fmt.num_planes, csi->scratch.size);
+	sun4i_csi_log_regs(csi, "start_streaming-entry");
 
 	csi->sequence = 0;
 
@@ -260,6 +360,9 @@
 						csi->scratch.size,
 						&csi->scratch.paddr,
 						GFP_KERNEL);
+	dev_info(csi->dev,
+		 "start_streaming: scratch vaddr=%p paddr=0x%pad size=%zu\n",
+		 csi->scratch.vaddr, &csi->scratch.paddr, csi->scratch.size);
 	if (!csi->scratch.vaddr) {
 		dev_err(csi->dev, "Failed to allocate scratch buffer\n");
 		ret = -ENOMEM;
@@ -295,6 +398,9 @@
 	       CSI_CFG_HREF_POL(href_pol) |
 	       CSI_CFG_PCLK_POL(pclk_pol),
 	       csi->regs + CSI_CFG_REG);
+	dev_info(csi->dev,
+		 "start_streaming: href_pol=%lu vref_pol=%lu pclk_pol=%lu\n",
+		 href_pol, vref_pol, pclk_pol);
 
 	/*
 	 * suniv F1C100S has a per-byte/per-line mask register that A10
@@
 	writel(CSI_SCALE_PASSTHROUGH, csi->regs + CSI_SCALE_REG);
 	dev_info(csi->dev, "CSI_SCALE_REG after write: 0x%08x (wanted 0x%08x)\n",
 		 readl(csi->regs + CSI_SCALE_REG), CSI_SCALE_PASSTHROUGH);
 
 	/* Setup buffer length */
 	writel(csi->fmt.plane_fmt[0].bytesperline,
@@ -310,15 +416,19 @@
 	/* Enable double buffering */
 	writel(CSI_BUF_CTRL_DBE, csi->regs + CSI_BUF_CTRL_REG);
 
+	dev_info(csi->dev, "start_streaming: enabling INT_EN mask 0x%08x\n",
+		 CSI_INT_DEBUG_MASK);
 	/* Clear the pending interrupts */
-	writel(CSI_INT_FRM_DONE, csi->regs + CSI_INT_STA_REG);
+	writel(CSI_INT_DEBUG_MASK, csi->regs + CSI_INT_STA_REG);
 
-	/* Enable frame done interrupt */
-	writel(CSI_INT_FRM_DONE, csi->regs + CSI_INT_EN_REG);
+	/* Enable verbose interrupt reporting */
+	writel(CSI_INT_DEBUG_MASK, csi->regs + CSI_INT_EN_REG);
 
 	sun4i_csi_capture_start(csi);
+	sun4i_csi_log_regs(csi, "start_streaming-after-start");
 
 	spin_unlock_irqrestore(&csi->qlock, flags);
+	dev_info(csi->dev, "start_streaming: calling source subdev s_stream(1)\n");
 
 	ret = v4l2_subdev_call(csi->src_subdev, video, s_stream, 1);
 	if (ret < 0 && ret != -ENOIOCTLCMD)
@@ -350,9 +460,11 @@
 	unsigned long flags;
 
 	dev_dbg(csi->dev, "Stopping capture\n");
+	sun4i_csi_log_regs(csi, "stop_streaming-entry");
 
 	v4l2_subdev_call(csi->src_subdev, video, s_stream, 0);
 	sun4i_csi_capture_stop(csi);
+	sun4i_csi_log_regs(csi, "stop_streaming-after-stop");
 
 	/* Release all active buffers */
 	spin_lock_irqsave(&csi->qlock, flags);
@@ -379,19 +491,28 @@
 	u32 reg;
 
 	reg = readl(csi->regs + CSI_INT_STA_REG);
+	sun4i_csi_log_irq_bits(csi, reg);
 
 	/* Acknowledge the interrupts */
 	writel(reg, csi->regs + CSI_INT_STA_REG);
 
+	if (reg & (CSI_INT_HBLANK_OVERFLOW | CSI_INT_FIFO2_OVERFLOW |
+		   CSI_INT_FIFO1_OVERFLOW | CSI_INT_FIFO0_OVERFLOW))
+		sun4i_csi_log_regs(csi, "irq-overflow");
+
 	if (!(reg & CSI_INT_FRM_DONE))
 		return IRQ_HANDLED;
 
+	sun4i_csi_log_slot_state(csi, "irq-before-flip", 0);
+	sun4i_csi_log_slot_state(csi, "irq-before-flip", 1);
 	spin_lock(&csi->qlock);
 	if (sun4i_csi_buffer_flip(csi, csi->sequence++)) {
 		dev_warn(csi->dev, "%s: Flip failed\n", __func__);
 		sun4i_csi_capture_stop(csi);
 	}
 	spin_unlock(&csi->qlock);
+	sun4i_csi_log_slot_state(csi, "irq-after-flip", 0);
+	sun4i_csi_log_slot_state(csi, "irq-after-flip", 1);
 
 	return IRQ_HANDLED;
 }
