#!/bin/sh

mount -t proc proc /proc
mount -t sysfs sysfs /sys
mount -t devtmpfs devtmpfs /dev
mkdir -p /dev/pts /dev/shm
mount -t devpts devpts /dev/pts
mount -t tmpfs tmpfs /tmp
mount -t tmpfs tmpfs /run

hostname f1c200s

# Composite USB gadget: CDC ECM (ethernet) + CDC ACM (serial console over USB)
# Host sees both `usb0` and `/dev/ttyACM0` from the single USB-C cable.
mountpoint -q /sys/kernel/config || mount -t configfs none /sys/kernel/config

# Wait up to 5 s for MUSB to register a UDC
i=0; while [ $i -lt 5 ] && [ -z "$(ls /sys/class/udc 2>/dev/null)" ]; do sleep 1; i=$((i+1)); done
UDC=$(ls /sys/class/udc 2>/dev/null | head -n1)

if [ -n "$UDC" ]; then
	G=/sys/kernel/config/usb_gadget/g1
	mkdir -p "$G" && cd "$G"
	echo 0x1d6b > idVendor          # Linux Foundation
	echo 0x0104 > idProduct         # Multifunction Composite
	echo 0x0100 > bcdDevice
	echo 0x0200 > bcdUSB
	mkdir -p strings/0x409
	echo "F1C200S" > strings/0x409/manufacturer
	echo "F1C200S Dev Board" > strings/0x409/product
	cat /proc/sys/kernel/random/uuid > strings/0x409/serialnumber
	mkdir -p configs/c.1/strings/0x409
	echo "ECM+ACM" > configs/c.1/strings/0x409/configuration
	echo 250 > configs/c.1/MaxPower
	mkdir -p functions/ecm.usb0
	mkdir -p functions/acm.GS0
	ln -s functions/ecm.usb0 configs/c.1/
	ln -s functions/acm.GS0 configs/c.1/
	echo "$UDC" > UDC
	cd - >/dev/null
	ifconfig usb0 192.168.100.1 netmask 255.255.255.0 up 2>/dev/null
	setsid /sbin/getty -L ttyGS0 115200 vt100 >/dev/null 2>&1 &
fi

# WiFi - auto-connect if configured
if [ -f /etc/wpa_supplicant.conf ]; then
	wpa_supplicant -B -i wlan0 -c /etc/wpa_supplicant.conf 2>/dev/null
	udhcpc -b -i wlan0 -q 2>/dev/null &
fi

echo ""
echo "  F1C200S Dev Board"
echo "  64MB RAM | ARM926EJ-S | kernel $(uname -r)"
echo ""
echo "  Serial console: ttyS0 @ 115200"
echo "  USB Ethernet:   192.168.100.1 (set host to 192.168.100.2)"
echo "  USB Serial:     /dev/ttyACM0 on host side"
if [ -f /etc/wpa_supplicant.conf ]; then
echo "  WiFi:           connecting..."
fi
echo "  SSH:            ssh root@<ip>  (password: root)"
echo ""
